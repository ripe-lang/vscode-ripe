{
	"comments": {
		"lineComment": "//",
		"blockComment": ["/*", "*/"]
	},
	"brackets": [
		["{", "}"],
		["[", "]"],
		["(", ")"]
	],
	"autoClosingPairs": [
		["{", "}"],
		["[", "]"],
		["(", ")"],
		["\"", "\""]
	],
	"surroundingPairs": [
		["{", "}"],
		["[", "]"],
		["(", ")"],
		["\"", "\""]
	],
	"wordPattern": "[A-Za-z_][A-Za-z0-9_]*",
	"folding": {
		"markers": {
			"start": "^\\s*//\\s*region\\b",
			"end": "^\\s*//\\s*endregion\\b"
		}
	}
}
