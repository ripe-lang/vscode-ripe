{
  "name": "vscode-ripe",
  "displayName": "Ripe",
  "description": "Syntax highlighting for the Ripe programming language",
  "version": "0.0.1",
  "publisher": "ripe-lang",
  "repository": {
    "type": "git",
    "url": "https://github.com/ripe-lang/vscode-ripe"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "ripe",
        "aliases": ["Ripe", "ripe"],
        "extensions": [".rp"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ripe",
        "scopeName": "source.ripe",
        "path": "./syntaxes/ripe.tmLanguage.json"
      }
    ]
  }
}
